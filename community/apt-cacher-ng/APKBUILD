# Contributor:
# Maintainer:
pkgname=apt-cacher-ng
pkgver=3.1
pkgrel=0
pkgdesc="Apt-Cacher NG is a caching HTTP proxy intended for use with download clients of system distribution's package managers."
url="https://alioth.debian.org/projects/apt-cacher-ng/"
arch="all"
license="BSD-4 ZLIB public-domain"
depends="zlib openssl xz bzip2 fuse"
makedepends="cmake zlib-dev openssl-dev xz-dev bzip2-dev fuse-dev"
install=""
subpackages="$pkgname-doc"
source="http://deb.debian.org/debian/pool/main/a/${pkgname}/${pkgname}_${pkgver}.orig.tar.xz
	0001-disable-acngtool.patch"
builddir="$srcdir/"
options="!check"

build() {
	mkdir build && cd build
	cmake -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_BUILD_TYPE=Release ../$pkgname-$pkgver
	make
}

package() {
	make -C $builddir/build DESTDIR="$pkgdir" install
}

